{
  "displayName": "SmartThings WindFree AC",
  "name": "homebridge-smartthings-windfree-ac",
  "version": "0.1.0-beta.3",
  "description": "Homebridge plugin for Samsung WindFree air conditioners via SmartThings with OAuth2 setup, discovery, and optional HomeKit controls.",
  "license": "Apache-2.0",
  "private": false,
  "author": "snappytoes1",
  "maintainers": [
    {
      "name": "snappytoes1",
      "email": "snappytoes1@users.noreply.github.com"
    }
  ],
  "homepage": "https://github.com/snappytoes1/homebridge-smartthings-windfree-ac#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/snappytoes1/homebridge-smartthings-windfree-ac.git"
  },
  "bugs": {
    "url": "https://github.com/snappytoes1/homebridge-smartthings-windfree-ac/issues"
  },
  "engines": {
    "node": "^22.10.0 || ^24.0.0",
    "npm": ">=10"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "homebridge-ui",
    "config.schema.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/build.cjs",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "pack:dry-run": "npm pack --dry-run",
    "verify": "npm run lint && npm run build && npm test && npm run pack:dry-run",
    "prepack": "npm run build"
  },
  "keywords": [
    "homebridge-plugin",
    "homebridge",
    "smartthings",
    "samsung",
    "windfree",
    "air-conditioner",
    "homekit"
  ],
  "peerDependencies": {
    "homebridge": ">=2.1.0"
  },
  "peerDependenciesMeta": {
    "homebridge": {
      "optional": true
    }
  },
  "dependencies": {
    "@homebridge/plugin-ui-utils": "^2.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "homebridge": "^2.2.0",
    "rimraf": "^6.0.1",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
